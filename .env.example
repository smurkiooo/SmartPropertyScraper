# Скопируй в .env и адаптируй под своё окружение.
# docker compose up автоматически подхватит этот файл.

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Параметры, которые читает Python-код (src/realty_scraper/s3_utils.py)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=realty
S3_REGION=us-east-1
